__pycache__/
.claude/

# Video primary sources — kept locally per manifest entries (URL + sha256)
# but excluded from git remote due to file-size limits. Already-tracked
# small videos (e.g., the 5.6 MB FLIR1 file) stay tracked because
# gitignore does not retroactively untrack files; new additions need
# `git add -f` to override this rule.
sources/video/

# Session credentials — never commit. yt-dlp / Firefox cookies.txt files
# authenticate full Google account access (SID, SAPISID, __Secure-*PSID,
# LOGIN_INFO). The pre-commit `cookies-check` gate (scripts/tests/cookies-check.sh)
# is the defensive backstop if a renamed file slips past these patterns.
cookies.txt
yt-cookies*.txt
*.cookies.txt
*cookies.sqlite*

# yt-dlp gotcha — `--cookies -` is interpreted as a literal filename, and
# yt-dlp writes refreshed cookies back to a file named `-` in the working
# directory after the run. scripts/tools/download-video.py and transcribe.py
# avoid this by using `--cookies-from-browser firefox` and `--cookies /dev/stdin`
# respectively, but the gitignore entry is defense-in-depth in case a future
# tool or contributor command leaks via `-`. See scripts/tools/VIDEO-PIPELINE.md
# "Cookies — when, why, and the dangerous form" for the canonical workflow.
/-

# yt-dlp partial / temp / metadata artifacts. Same memory-only discipline
# concern: a future yt-dlp version or flag combination could persist
# auth-bearing state here.
*.part
*.ytdl
*.live_chat.json

# Photo-identity working area. detect-faces.py writes unlabeled face crops
# here; they're working state to be reviewed and either registered as
# baselines (which DO get committed under baselines/) or pruned. The crops/
# directory itself is tracked (via .gitkeep) so the layout is reproducible;
# only the working .jpg accumulation is excluded. See
# scripts/tools/VIDEO-PIPELINE.md and sources/photo-identity-log/README.md.
sources/photo-identity-log/crops/*.jpg
sources/photo-identity-log/crops/*.jpeg
sources/photo-identity-log/crops/*.png

# Per-session detect-faces log. Working state only — manifest.yaml is the
# authoritative baseline registry (sha256, source-video, timestamp, bbox,
# added_date for every baseline). index.csv is regenerated by detect-faces.py
# and auto-prunes rows whose crops/* paths no longer exist.
sources/photo-identity-log/index.csv
